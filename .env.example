# MongoDB Connection
MONGODB_URI=your_mongodb_atlas_uri

# JWT Configuration
JWT_SECRET=your_jwt_secret_key

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Aamarpay Configuration
AAMARPAY_MODE=sandbox # change to 'live' for production
AAMARPAY_STORE_ID=your_store_id
AAMARPAY_SIGNATURE_KEY=your_signature_key
AAMARPAY_API_URL=https://sandbox.aamarpay.com/jsonpost.php # https://secure.aamarpay.com/jsonpost.php for live
AAMARPAY_CURRENCY=BDT

# Application URLs
FRONTEND_URL=https://your-frontend-proxy.vercel.app
API_URL=https://your-backend-proxy.onrender.com

# Email Configuration (Nodemailer)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
